# ============================================================
# bunq Aether — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Frontend origin for CORS (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ────────────────────────────────────────────────
# Leave DATABASE_URL empty to use local SQLite (file at ./server/data/aether.db).
# For AWS RDS MariaDB (production), set e.g.:
#   DATABASE_URL=mysql://aether:STRONG_PASSWORD@your-rds.xxx.eu-west-1.rds.amazonaws.com:3306/aether
# The schema + queries are written in ANSI-portable SQL — nothing else changes.
DATABASE_URL=
DB_POOL_SIZE=10
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Optional: user scope for the memory store (defaults to "single-user").
# Setting this to a real bunq user id makes the schema multi-user-ready.
# BUNQ_USER_ID=3626159

# Secret for signing session tokens / request validation
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=CHANGE_ME_generate_a_random_32_byte_hex_string

# ── AI Providers ─────────────────────────────────────────────
# Which provider to use by default: claude | gemini | ollama
DEFAULT_AI_PROVIDER=claude

# Anthropic / Claude
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (cheapest: gemini-2.0-flash-lite)
# Get your key at: https://aistudio.google.com/app/apikey
# Also used for Gemini TTS (gemini-2.5-flash-preview-tts) — same key
GEMINI_API_KEY=AIza...

# ElevenLabs TTS — preferred voice engine (warmer, streams audio, lowest latency).
# Free tier: 10,000 chars/mo. Get your key at: https://elevenlabs.io/app/settings/api-keys
# Leave blank to fall back to Gemini TTS.
ELEVENLABS_API_KEY=
# Voice IDs: https://elevenlabs.io/app/voice-library
# Default: "Sarah" (EXAVITQu4vr4xnSDxMAL) — warm, conversational, friend-like.
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMAL
# Models: eleven_flash_v2_5 (~75ms, fastest), eleven_turbo_v2_5 (~275ms, richer),
#         eleven_multilingual_v2 (highest quality, non-streaming feel)
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Ollama (local, no key needed — just point to the running instance)
# Default port when running `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434
# Which model to use — run `ollama pull llama3.2` or `ollama pull mistral`
OLLAMA_MODEL=llama3.2

# ── bunq API ─────────────────────────────────────────────────
# Production: https://api.bunq.com/v1
# Sandbox:    https://public-api.sandbox.bunq.com/v1
BUNQ_API_BASE=https://public-api.sandbox.bunq.com/v1
BUNQ_API_KEY=your_bunq_api_key_here
BUNQ_OAUTH_CLIENT_ID=your_bunq_oauth_client_id
BUNQ_OAUTH_CLIENT_SECRET=your_bunq_oauth_client_secret
BUNQ_REDIRECT_URI=http://localhost:3000/oauth/callback
