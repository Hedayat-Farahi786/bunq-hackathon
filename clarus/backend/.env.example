# ---- Core ----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma separated. Used for ALLOWED_HOSTS.
ALLOWED_HOSTS=localhost,127.0.0.1
# Frontend origin(s) for CORS, comma separated.
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Where the SPA lives (used to build OAuth redirect URLs back to the app).
FRONTEND_URL=http://localhost:5173
# Public base URL of THIS backend (used as the OAuth callback host).
BACKEND_URL=http://localhost:8000

# ---- Database ----
# Defaults to SQLite if unset. For production set e.g.
# DATABASE_URL=postgres://user:pass@host:5432/clarus
# DATABASE_URL=

# ---- AI (Gemini via OpenAI-compatible endpoint) ----
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# ---- Integrations: OAuth apps (fill the ones you use) ----
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitLab Application: https://gitlab.com/-/profile/applications
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# Atlassian/Jira 3LO app: https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# Slack app: https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
